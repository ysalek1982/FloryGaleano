VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>
VITE_SUPABASE_ANON_KEY=<optional-legacy-anon-key>
VITE_APP_ENV=development
VITE_APP_VERSION=0.0.0
VITE_SENTRY_DSN=<optional-sentry-dsn>

# Supabase CLI / deployment values. Keep real values in your shell environment only.
SUPABASE_PROJECT_REF=<your-project-ref>
SUPABASE_PROJECT_REF_STAGING=<your-staging-project-ref>
SUPABASE_DB_PASSWORD_STAGING=<your-staging-database-password>
SUPABASE_PROJECT_REF_PRODUCTION=<your-production-project-ref>
SUPABASE_DB_PASSWORD_PRODUCTION=<your-production-database-password>
SUPABASE_ACCESS_TOKEN=<your-supabase-access-token>
SUPABASE_DB_PASSWORD=<your-database-password>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
APP_SUPABASE_SERVICE_ROLE_KEY=<optional-edge-function-service-role-secret>

# Supabase Edge Function secrets. Set with `npx supabase secrets set ...`.
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash

# Optional hosting / monitoring CI secrets. Do not expose these to the browser.
VERCEL_TOKEN=<your-vercel-token>
VERCEL_ORG_ID=<your-vercel-org-id>
VERCEL_PROJECT_ID=<your-vercel-project-id>
SENTRY_AUTH_TOKEN=<optional-sentry-auth-token>
STAGING_URL=https://your-staging-preview.example
PRODUCTION_URL=https://your-production-domain.example
