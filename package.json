    "test:e2e:ui": "playwright test --ui",
    "validate:env": "node scripts/validate-env.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "test:rls": "node scripts/remote-qa.mjs rls",
    "test:supabase": "node scripts/remote-qa.mjs supabase",
    "smoke": "node scripts/remote-qa.mjs smoke",
    "smoke:staging": "node scripts/post-deploy-smoke.mjs staging",
    "smoke:production": "node scripts/post-deploy-smoke.mjs production",
    "staging:checklist": "node scripts/staging-checklist.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
